{
  "builds": [
    {
      "src": "backend/XStreamerMusicWebApp/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(api|admin|dashboard|giveaways)(/.*)?",
      "dest": "backend/XStreamerMusicWebApp/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}