{
  "version": 2,
  "builds": [
    {
      "src": "backend/XStreamerMusicWebApp/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/(api|admin|dashboard)(/.*)?$",
      "dest": "backend/XStreamerMusicWebApp/wsgi.py"
    }
  ]
}