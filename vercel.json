{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "backend/XStreamerMusicWebApp/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/XStreamerMusicWebApp/wsgi.py"
    },
    {
      "source": "/admin/:path*",
      "destination": "/backend/XStreamerMusicWebApp/wsgi.py"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/backend/XStreamerMusicWebApp/wsgi.py"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/dist/index.html"
    }
  ]
}